                    </StackPanel>
                    <StackPanel Margin="0,10,0,0">
                        <TextBlock Text="2.Fody" Margin="20,0,0,5" FontSize="16" VerticalAlignment="Top" HorizontalAlignment="Left" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
