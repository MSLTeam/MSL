        <controls:MagicCard Margin="0,0,0,20" Title="赞助 (Sponsor)">
            <StackPanel>
                <TextBlock Text="{Binding [Page_About_SponsorText], Source={x:Static langs:LanguageManager.Instance}}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <hc:Shield Subject="https://afdian.com/a/MSLTeam" Status="{Binding [OpenWebsite], Source={x:Static langs:LanguageManager.Instance}}" Margin="0,5,0,0" Command="hc:ControlCommands.OpenLink" CommandParameter="https://afdian.com/a/makabaka123" HorizontalAlignment="Center"/>
