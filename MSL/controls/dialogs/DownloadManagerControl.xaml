<UserControl x:Class="MSL.controls.dialogs.DownloadManagerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MSL.controls.dialogs"
             xmlns:control="clr-namespace:MSL.controls"
             xmlns:hc="https://handyorg.github.io/handycontrol"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <control:MagicCard Title="下载管理器" BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 下载项列表 -->
            <control:MagicListBox1 x:Name="DownloadItemsListView" hc:Empty.ShowEmpty="True" MinHeight="100"  BorderThickness="0"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Single" HorizontalContentAlignment="Stretch">
                <control:MagicListBox1.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <!-- 隐藏控制 -->
                        <Setter Property="Visibility" Value="{Binding ItemVisibility}" />
                        <!-- 禁用选中高亮效果 -->
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border BorderThickness="1" CornerRadius="7" Margin="3"
                                            Padding="7" BorderBrush="{DynamicResource BorderBrush}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </control:MagicListBox1.ItemContainerStyle>
                <control:MagicListBox1.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- 文件名和URL -->
                            <Grid Grid.Row="0" Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Filename}" TextTrimming="CharacterEllipsis"
                                           FontWeight="DemiBold" Style="{StaticResource MagicText14}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Url}" TextTrimming="CharacterEllipsis"
                                           Opacity="0.7" Style="{StaticResource MagicText}" VerticalAlignment="Center"/>
                            </Grid>
                            

                            <!-- 进度条 -->
                            <ProgressBar Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,5"
                                     Value="{Binding Progress.ProgressPercentage}" Style="{StaticResource ProgressBarFlat}"
                                     Height="3"/>

                            <!-- 下载信息和状态 -->
                            <WrapPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,5,0,0">
                                <TextBlock Style="{StaticResource MagicText}" Margin="0,0,15,0" VerticalAlignment="Center">
                                    <Run Text="{Binding Progress.ProgressPercentage}"/><Run Text="%"/>
                                    <Run Text="  "/>
                                    <Run Text="速度："/>
                                    <Run Text="{Binding SpeedText}"/>
                                    <Run Text="  "/>
                                    <Run Text=" 剩余时间："/>
                                    <Run Text="{Binding RemainingText}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding StatusText}" Style="{StaticResource MagicText}"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </WrapPanel>

                            <!-- 操作按钮 -->
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="PauseResumeButton" Content="{Binding PauseResumeButtonText}" 
                                    Width="60" Margin="0,0,5,0" Tag="{Binding ItemId}"
                                    Click="PauseResumeButton_Click"/>
                                <Button x:Name="CancelRemoveButton" Content="{Binding CancelRemoveButtonText}" 
                                    Width="60" Tag="{Binding ItemId}"
                                    Click="CancelRemoveButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </control:MagicListBox1.ItemTemplate>
            </control:MagicListBox1>

            <!-- 底部控制区 -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="正在下载: " VerticalAlignment="Center"/>
                    <TextBlock x:Name="ActiveDownloadsTextBlock" Text="0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="PauseAllButton" Content="全部暂停" Width="80" Margin="15,0,5,0" Click="PauseAllButton_Click"/>
                    <Button x:Name="ResumeAllButton" Content="全部继续" Width="80" Margin="0,0,5,0" Click="ResumeAllButton_Click"/>
                    <Button x:Name="CancelAllButton" Content="全部取消" Width="80" Margin="0,0,5,0" Click="CancelAllButton_Click"/>
                    <Button x:Name="RemoveCompletedButton" Content="移除已完成/已取消" Width="150" Click="RemoveCompletedButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </control:MagicCard>
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
</UserControl>
